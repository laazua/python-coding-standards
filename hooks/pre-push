#!/usr/bin/env bash
# =============================================================================
# Pre-push Hook — Python Coding Standards
# =============================================================================
# Runs full type validation and linting on all Python files before each push.
# This is more thorough than pre-commit (type checking is expensive).
#
# Install: cp hooks/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push
# =============================================================================

set -euo pipefail

# --- Configuration ----------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"
PROJECT_ROOT="$(git rev-parse --show-toplevel)"

# --- Colors -----------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}[pre-push] Running comprehensive Python quality checks...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Find all Python files, excluding virtual environments and generated code
ALL_PYTHON_FILES=$(find "$PROJECT_ROOT" \
    -name "*.py" \
    -not -path "*/.venv/*" \
    -not -path "*/venv/*" \
    -not -path "*/.tox/*" \
    -not -path "*/migrations/*" \
    -not -path "*/__pycache__/*" \
    -not -path "*/node_modules/*" \
    -not -path "*/.eggs/*" \
    -not -path "*/build/*" \
    -not -path "*/dist/*" \
    2>/dev/null || true)

if [ -z "$ALL_PYTHON_FILES" ]; then
    echo -e "${GREEN}[pre-push] No Python files found — skipping.${NC}"
    exit 0
fi

FILE_COUNT=$(echo "$ALL_PYTHON_FILES" | wc -l)
echo -e "${YELLOW}[pre-push] Found ${FILE_COUNT} Python file(s) to check.${NC}"
echo ""

FAILED=0

# --- Step 1: Type validation (mypy) -----------------------------------------
echo -e "${BLUE}═══ Type Validation (mypy) ═══${NC}"

# Run type validation on each file
while IFS= read -r file; do
    if [ -f "$file" ]; then
        if python "$SCRIPT_DIR/type_validator.py" "$file" 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} $file — types OK"
        else
            echo -e "  ${RED}✗${NC} $file — type issues detected (see above)"
            FAILED=1
        fi
    fi
done <<< "$ALL_PYTHON_FILES"

# --- Step 2: Run tests if they exist ----------------------------------------
echo ""
echo -e "${BLUE}═══ Unit Tests ═══${NC}"

if [ -d "$PROJECT_ROOT/tests" ] && [ -f "$PROJECT_ROOT/tests/__init__.py" ]; then
    if python -m pytest "$PROJECT_ROOT/tests/" -x --tb=short 2>/dev/null; then
        echo -e "  ${GREEN}✓${NC} All tests passed"
    else
        echo -e "  ${RED}✗${NC} Tests failed (see above)"
        FAILED=1
    fi
else
    echo -e "  ${YELLOW}⚠${NC}  No test directory found — skipping tests"
fi

# --- Result ------------------------------------------------------------------
echo ""
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}[pre-push] FAILED — Fix the issues above before pushing.${NC}"
    echo -e "${YELLOW}Hints:${NC}"
    echo -e "  • Run 'python scripts/auto_formatter.py <file>' to fix formatting"
    echo -e "  • Run 'python scripts/type_validator.py <file>' for type checking"
    echo -e "  • Run 'python scripts/pep8_checker.py <file>' for PEP8 checking"
    exit 1
else
    echo -e "${GREEN}[pre-push] PASSED — All quality checks passed. Push allowed.${NC}"
    exit 0
fi
