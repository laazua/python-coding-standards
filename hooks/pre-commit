#!/usr/bin/env bash
# =============================================================================
# Pre-commit Hook — Python Coding Standards
# =============================================================================
# Runs auto-formatter and PEP8 check on staged Python files before each commit.
# Exits with non-zero if any issues are found, preventing the commit.
#
# Install: cp hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# =============================================================================

set -euo pipefail

# --- Configuration ----------------------------------------------------------
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"

# --- Colors -----------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# --- No Python files? Skip --------------------------------------------------
if [ -z "$STAGED_FILES" ]; then
    echo -e "${GREEN}[pre-commit] No staged Python files — skipping.${NC}"
    exit 0
fi

echo -e "${YELLOW}[pre-commit] Checking ${STAGED_FILES}...${NC}"
FAILED=0

# --- Step 1: Auto-format each staged file ------------------------------------
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if python "$SCRIPT_DIR/auto_formatter.py" "$file" --check 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} $file — formatting OK"
        else
            echo -e "  ${RED}✗${NC} $file — formatting issues found"
            # Apply formatting automatically
            python "$SCRIPT_DIR/auto_formatter.py" "$file" 2>/dev/null || true
            git add "$file"
            echo -e "  ${YELLOW}  → Auto-formatted and re-staged${NC}"
        fi
    fi
done

# --- Step 2: PEP8 compliance check -------------------------------------------
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        if python "$SCRIPT_DIR/pep8_checker.py" "$file" 2>/dev/null; then
            echo -e "  ${GREEN}✓${NC} $file — PEP8 compliant"
        else
            echo -e "  ${RED}✗${NC} $file — PEP8 violations (see above)"
            FAILED=1
        fi
    fi
done

# --- Result ------------------------------------------------------------------
if [ "$FAILED" -eq 1 ]; then
    echo -e "\n${RED}[pre-commit] FAILED — PEP8 violations must be fixed before commit.${NC}"
    echo -e "${YELLOW}Hint: Run 'python scripts/auto_formatter.py <file>' to fix formatting.${NC}"
    exit 1
else
    echo -e "${GREEN}[pre-commit] PASSED — All checks passed.${NC}"
    exit 0
fi
